#!/usr/bin/env zsh
PATH="${OLDPATH}"

if (( ${#_AUTOENV_DOTENV_VARS} )); then
    unset "${_AUTOENV_DOTENV_VARS[@]}"
fi
unset _AUTOENV_DOTENV_VARS

unset OLDPATH
unalias cake \
    phpcbf \
    phpcs \
    phpstan \
    phpunit \
    sqlcmd \
    supervisorctl \
    toggle_docker \

# unfunction phptrace
unfunction elasticcc
unfunction subscribble
unfunction http
unfunction strim
unfunction rebase-onto-develop
unfunction run_in_docker
unfunction sync_elastic
unfunction test_run
unfunction test_run_local_newman
