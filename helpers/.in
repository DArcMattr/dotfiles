function test_run_local_newman {
    local env='xxx'
    local workspace='xxx'
    npx newman run './postman/test_collection.json' \
        --verbose \
        --insecure \
        --postman-api-key ${POSTMAN_API_KEY} \
        --environment ${env} \
        --working-dir "${0:A:h}" \
        --reporters cli,postman-cloud,htmlextra \
        --reporter-postman-cloud-apiKey ${POSTMAN_API_KEY} \
        --reporter-postman-cloud-workspaceId ${workspace}
}

function test_run {
    case "${1}" in
        prod) ENV='xxx'
            ;;

        stage) ENV='xxx'
            ;;

        dev) ENV='xxx'
            ;;

        local|*) ENV='xxx'
            ;;
    esac

    (
        cd "${0:A:h}/postman"
        postman collection run xxx \
            --verbose \
            --insecure \
            --postman-api-key ${POSTMAN_API_KEY} \
            --environment ${ENV} \
            -i xxx
    )
}

# function phptrace {
#
# }

http () {
    local extra_args=()
    while getopts ":x" opt
    do
        case "${opt}" in
            (x) extra_args+=('x-impersonation-id:${impersonation_id}') ;;
        esac
    done
    shift $((OPTIND - 1))
    ${HOME}/.local/bin/http -jv --verify no --auth-type bearer --auth "${bearer}" "${@}" "${extra_args[@]}"
}

function sync_elastic {
    REMOTE='xxx'
    LOCAL='http://api-tracker-elastic:9200'
    curl -XDELETE "${LOCAL}/dev_tickets"
    curl -XPUT "${LOCAL}/dev_tickets" \
        -H 'Content-Type: application/json' \
        -d "$( \
                curl "${REMOTE}/stage_tickets" \
                    | jq '.stage_tickets | del(.settings.index.provided_name, .settings.index.creation_date, .settings.index.uuid, .settings.index.version, .settings.index.resize, .settings.index.routing)' \
            )"

        curl -XPOST "${LOCAL}/_reindex?wait_for_completion=false&pretty" \
            -H 'Content-Type: application/json' \
            --data @- << EOL
{
  "source": {
    "remote": {
      "host": "${REMOTE}"},
    "index": "stage_tickets",
    "query": {
      "match_all": {}
    }
  },
  "dest": {
    "index": "dev_tickets",
    "op_type": "create"
  }
}
EOL
    curl -XPUT "${LOCAL}/dev_tickets" \
        -H 'Content-Type: application/json' \
        --data @- << EOL
{
  "index.search.slowlog.threshold.query.trace": "0s",
  "index.search.slowlog.level": "trace"
}
EOL
    curl -XDELETE "${LOCAL}/dev_ticket_events"
    curl -XPUT "${LOCAL}/dev_ticket_events" \
        -H 'Content-Type: application/json' \
        -d "$( \
                curl "${REMOTE}/stage_ticket_events" \
                    | jq '.stage_ticket_events | del(.settings.index.provided_name, .settings.index.creation_date, .settings.index.uuid, .settings.index.version, .settings.index.resize, .settings.index.routing)' \
            )"

        curl -XPOST "${LOCAL}/_reindex?wait_for_completion=false&pretty" \
            -H 'Content-Type: application/json' \
            --data @- << EOL
{
  "source": {
    "remote": {
      "host": "${REMOTE}"},
    "index": "stage_ticket_events",
    "query": {
      "match_all": {}
    }
  },
  "dest": {
    "index": "dev_ticket_events",
    "op_type": "create"
  }
}
EOL
}
