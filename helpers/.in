function subscribble {
  parallel --line-buffer ::: \
    'docker compose exec api /usr/local/bin/php /var/www/html/bin/cake.php subscribe epicor -p darc' \
    'docker compose exec api /usr/local/bin/php /var/www/html/bin/cache.php subscribe default -p darc'
}

function rebase-onto-develop {
    git fetch origin && git rebase --onto origin/develop HEAD~1
}

