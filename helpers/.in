function elasticcc {
    ssh others \
        'cd /etc/docker/compose/elasticsearch && \
            docker compose logs elasticsearch-01 elasticsearch-02 elasticsearch-03 --follow' | \
        awk '/elasticsearch\.slowlog\.source/ && !/1245060/ {$1=$2=""; print $0 }' | \
        jq .
}

function run_in_docker {
   docker compose exec  --user ${CMD_USER:-'www-data'} ${SERVICE:-'api'} ${@}
}

function strim {
    tail -n 100 -F "${1}" | \
        sed 's# - #\n&#g' | \
        sed 's#\\\\#\\#g' | \
        sed 's#\\n#\n#g'  | \
        sed 's#\\r##g'
}

