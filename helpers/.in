#!/usr/bin/env zsh
export OLDPATH=${PATH}
export PATH="${0:A:h}/bin:${0:A:h}/app/vendor/bin:${PATH}"

typeset -ga _AUTOENV_DOTENV_VARS=()
if [[ -r "${0:A:h}/.env" ]]; then
    local _line _key
    while IFS= read -r _line || [[ -n $_line ]]; do
        [[ $_line =~ ^[[:space:]]*(#|$) ]] && continue
        [[ $_line =~ ^([A-Za-z_][A-Za-z0-9_]*)= ]] || continue
        _key="${match[1]}"
        (( ${+parameters[$_key]} )) && [[ -n "${(P)_key}" ]] && continue
        eval "export $_line"
        _AUTOENV_DOTENV_VARS+=("$_key")
    done < "${0:A:h}/.env"
fi

# cake subscribe epicor  --queue darc
# cake subscribe default --queue darc

function subscribble {
    trap 'docker compose exec -T api supervisorctl stop "subscribe_default:*" "subscribe_epicor:*"; echo "subscribers stopped"; trap - INT TERM EXIT' INT TERM EXIT
    docker compose exec -T api supervisorctl start 'subscribe_default:*' 'subscribe_epicor:*'
    echo "Subscribers running. Ctrl-C to stop."
    sleep infinity
}

function rebase-onto-develop {
    git fetch origin && git rebase --onto origin/develop HEAD~1
}

alias cake='docker compose exec api /usr/local/bin/php /var/www/html/bin/cake.php'
alias supervisorctl='docker compose exec api /usr/bin/supervisorctl'
