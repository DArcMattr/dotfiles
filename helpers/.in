function test_run_local_newman {
    npx newman run './postman/test_collection.json' \
        --verbose \
        --insecure \
        --postman-api-key ${POSTMAN_API_KEY} \
        --environment ${POSTMAN_ENV_LOCAL} \
        --working-dir "${0:A:h}" \
        --reporters cli,postman-cloud,htmlextra \
        --reporter-postman-cloud-apiKey ${POSTMAN_API_KEY} \
        --reporter-postman-cloud-workspaceId ${POSTMAN_WORKSPACE_ID}
}

function test_run {
    case "${1}" in
        prod) ENV=${POSTMAN_ENV_PROD}
            ;;

        stage) ENV=${POSTMAN_ENV_STAGE}
            ;;

        dev) ENV=${POSTMAN_ENV_DEV}
            ;;

        local|*) ENV=${POSTMAN_ENV_LOCAL}
            ;;
    esac

    (
        cd "${0:A:h}/postman"
        postman collection run ${POSTMAN_COLLECTION_ID} \
            --verbose \
            --insecure \
            --postman-api-key ${POSTMAN_API_KEY} \
            --environment ${ENV} \
            -i ${POSTMAN_ITERATION_DATA_ID}
    )
}

