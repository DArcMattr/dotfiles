#!/usr/bin/env zsh

alias ll='ls -alFgh'
alias doge='doge -mh $(($(tput lines) -1))'
alias expected_install='./autogen.sh && ./configure --prefix=$HOME/.local && make install clean'
alias nvf='nvim $(fzf)'
alias snvim='sudo -e'

nvdno() {
  nvim $(git dno "${1:-@~1}")
}
compdef _git nvdno=git-checkout

unalias ls 2>/dev/null

if (( $+commands[lsd] )); then
  alias ls='lsd -F --group-directories-first'
elif ls --color=always -d . >/dev/null 2>&1; then
  alias ls='ls --color=always -F'
else
  alias ls='ls -F'
fi

dir() {
  local out
  out=$(ls -algh "${@}")
  {
    echo "$out" | grep "^d"
    echo "$out" | grep -v "^d" | grep -v "^total"
    echo "$out" | grep "^total"
  } | ${PAGER:-less}
}

alias key='\man -k'
alias info='info --vi-keys'
alias sicp='racket -i -p neil/sicp -l xrepl'
alias rgp='rg --pager=${PAGER}'
alias venv='python -m venv'
alias jsonize='jq .'

# Suffix aliases
if alias -s >/dev/null 2>&1; then
  alias -s css=nvim
  alias -s md=nvim
  alias -s rst=nvim
  alias -s scss=nvim
  alias -s txt=nvim
  alias -s php=nvim
  alias -s json=jsonize
fi

# Functions, used where aliases would break
cdl() {
  cd "${@}" && ll .
}

cdd() {
  cd "${@}" && dir .
}

echoerr() {
  printf "%s\n" "${*}" >&2;
}

path() {
  print -l ${path}
}

catmd() {
  local TMPFILE="$(mktemp).html"

  pandoc -s --embed-resources -c "${XDG_CONFIG_HOME}/pandoc/buttondown.css" \
    --metadata title="${1:-Markdown Preview}" \
    -t html5 -f gfm+smart "$1" -o "$TMPFILE"

  if command -v wslview >/dev/null 2>&1; then
    wslview "$TMPFILE"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$TMPFILE"
  elif [[ -n "$BROWSER" ]]; then
    $BROWSER "$TMPFILE"
  else
    lynx -force_html "$TMPFILE"
  fi
}

hgdiff() {
  nvim -d -c 'map q :qa!<CR>' <(hg cat "$1") "$1"
}

# from https://unix.stackexchange.com/a/67541
pushterms() {
  infocmp -x | ssh -t "${@}" 'cat > "~/nuterm.info" && tic -x "~/$nuterm.info"'
}

sssh() {
  [[ -z "$1" ]] && echo "Usage: sssh <host>" && return 1
  (TERM=screen-256color autossh -t "$1" 'source ${HOME}/dotfiles/.aliases && tmuxt') 2>/dev/null
}

_sssh_hosts() {
  local -a ssh_hosts
  local config_file="$HOME/.ssh/config"
  local hosts_dir="$HOME/.ssh/hosts"

  # 1. Parse the main config file for Host lines
  if [[ -f "$config_file" ]]; then
    ssh_hosts+=($(grep -i '^Host ' "$config_file" | awk '{for (i=2; i<=NF; i++) print $i}' | grep -v '*'))
  fi

  # 2. Parse all .ssh files in your include directory
  if [[ -d "$hosts_dir" ]]; then
    # Using 'cat' on the glob ensures we grab every Host entry in every file
    ssh_hosts+=($(grep -ih '^Host ' "$hosts_dir"/*.ssh 2>/dev/null | awk '{for (i=2; i<=NF; i++) print $i}' | grep -v '*'))
  fi

  # 3. deduplicate and provide to Zsh
  ssh_hosts=(${(u)ssh_hosts})

  _describe -t ssh-hosts 'defined ssh hosts' ssh_hosts
}

compdef _sssh_hosts sssh

superupdate() {
  if command -v pacman >/dev/null 2>&1; then
    # Prioritize 'yay' or 'paru' if available for CachyOS/AUR
    local aur_helper=$(command -v \yay || command -v \paru)
    sudo pacman -Syu
    [[ -n "$aur_helper" ]] && $aur_helper -Sua --devel
    command -v \flatpak >/dev/null && flatpak update -y
  elif command -v apt >/dev/null 2>&1; then
    \sudo apt update && sudo apt full-upgrade -y && sudo apt autoremove -y
  elif command -v pkg >/dev/null 2>&1; then # Modern FreeBSD
    \sudo \sh -c "pkg update && pkg upgrade && pkg autoremove"
  elif command -v apt-get 2>&1; then
    \sudo \sh -c " \
      \apt-get update && \
      \apt-get -y upgrade && \
      \apt-get -y dist-upgrade && \
      \apt-get -y autoclean && \
      \apt-get -y autoremove && \
      \apt-get -y clean"
  else
    echoerr "This script is not configured for your system."
  fi

  if typeset -f superupdate_local > /dev/null; then
    superupdate_local
  fi
}

pushkey() {
  if [ $# -eq 0 ]; then
    printf "
no input blah blah
" 1>&2
    return 1
  fi
  cat "${1}" | \
    ssh "${2}" "mkdir -p ~/.ssh ; cat >> ~/.ssh/authorized_keys ; chmod 700 ~/.ssh && chmod 600 ~/.ssh/authorized_keys"
}

git_id() {
  git hash-object "$1"
}
