#!/usr/bin/env zsh
unfunction sssh

sssh() {
	(TERM=xterm-256color autossh -t "${1}" 'tmux attach || tmux new') 2>/dev/null
}

[[ ! -r /home/darc/.opam/opam-init/init.zsh ]] || source /home/darc/.opam/opam-init/init.zsh  > /dev/null 2> /dev/null

# bun completions
[ -s "/home/darc/.local/_bun" ] && source "/home/darc/.local/_bun"

superupdate_local() {
  (cd ~/contrib/neovim && \
    git switch master && \
    git fetch origin --prune --prune-tags --force && \
    git merge --ff-only origin/master && \
    zig build install --prefix ${LOCAL} -Doptimize=ReleaseFast)
  rehash
  nvim --cmd "autocmd user LazyVimStarted lua require('lazy').sync()"
}

[ -f "${HOME}/.claude/hooks/peon-ping/completions.bash" ] && source "${HOME}/.claude/hooks/peon-ping/completions.bash"

if [ -z "$TMUX" ]; then
  tmuxt
fi
